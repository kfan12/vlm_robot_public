        <visual name="v">
          <geometry>
            <cylinder>
              <radius>0.05</radius>
              <length>0.2</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.9 0.8 0.0 1</ambient>
            <diffuse>1.0 0.9 0.0 1</diffuse>
            <specular>0.2 0.2 0.0 1</specular>
          </material>
        </visual>
        <collision name="c">
          <geometry>
            <cylinder>
              <radius>0.05</radius>
              <length>0.2</length>
            </cylinder>
          </geometry>
        </collision>
      </link>
    </model>

    <model name="cone_R4">
      <static>true</static>
      <pose>-1.0 0.2 0.1 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry>
            <cylinder>
              <radius>0.05</radius>
