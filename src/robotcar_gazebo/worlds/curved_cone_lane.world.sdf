            </cylinder>
          </geometry>
          <material>
            <ambient>0.9 0.8 0.0 1</ambient>
            <diffuse>1.0 0.9 0.0 1</diffuse>
            <specular>0.2 0.2 0.0 1</specular>
          </material>
        </visual>
        <collision name="c">
          <geometry>
            <cylinder>
              <radius>0.05</radius>
              <length>0.2</length>
            </cylinder>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- S-curve second half: centerline crests at (5,0.7) then reverses,
         passing through 0 near x=8 down to a (11,-0.7) trough. Same constant
         0.8 m gate width, so the lane swings left-then-right (an S). -->

    <model name="cone_L5">
      <static>true</static>
      <pose>0.0 1.1 0.1 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry>
            <cylinder>
              <radius>0.05</radius>
              <length>0.2</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.9 0.8 0.0 1</ambient>
            <diffuse>1.0 0.9 0.0 1</diffuse>
            <specular>0.2 0.2 0.0 1</specular>
          </material>
        </visual>
        <collision name="c">
          <geometry>
            <cylinder>
              <radius>0.05</radius>
              <length>0.2</length>
            </cylinder>
          </geometry>
        </collision>
      </link>
    </model>

