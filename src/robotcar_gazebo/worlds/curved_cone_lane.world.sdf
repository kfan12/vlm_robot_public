    <!-- Red goal cone — on the centerline just past the S, at the trough end. -->
    <model name="cone_goal">
      <static>true</static>
      <pose>6.8 -0.7 0.125 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.25</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.8 0.05 0.05 1</ambient>
            <diffuse>0.95 0.1 0.1 1</diffuse>
            <specular>0.3 0.05 0.05 1</specular>
          </material>
        </visual>
        <collision name="c">
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.25</length>
            </cylinder>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- ===================== Traffic signs =====================
         Textured billboards (model://, resolved via IGN_GAZEBO_RESOURCE_PATH
         pointing at robotcar_gazebo/models/signs). Placed roadside on the
         robot's right (negative y), board facing back toward the approaching
         robot (yaw=pi). Each sign cues the upcoming track feature so the VLM
         can read it before the maneuver. -->

    <!-- Left-curve warning: at the start, before the lane arcs left. -->
    <include>
      <name>sign_left</name>
      <uri>model://sign_left</uri>
      <pose>-4.0 -1.3 0 0 0 3.14159</pose>
    </include>

    <!-- Winding-road (S-curve) warning: just before the crest/reversal. -->
    <include>
      <name>sign_winding</name>
      <uri>model://sign_winding</uri>
      <pose>-1.0 -1.0 0 0 0 3.14159</pose>
    </include>

    <!-- Right-curve warning: after the crest, where the lane swings right. -->
    <include>
      <name>sign_right</name>
      <uri>model://sign_right</uri>
      <pose>2.0 -1.0 0 0 0 3.14159</pose>
    </include>

    <!-- Stop: ahead of the red goal cone (goal at 6.8,-0.7). -->
    <include>
      <name>sign_stop</name>
      <uri>model://sign_stop</uri>
      <pose>5.2 -1.7 0 0 0 3.14159</pose>
    </include>

  </world>
</sdf>