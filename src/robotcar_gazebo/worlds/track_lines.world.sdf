<?xml version="1.0"?>
<!-- AUTO-GENERATED by scripts/generate_track_lines.py - edit PARAMS there and re-run. -->
<sdf version="1.7">
  <world name="cone_lane">

    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="libignition-gazebo-physics-system.so"
      name="ignition::gazebo::systems::Physics" />
    <plugin filename="libignition-gazebo-user-commands-system.so"
      name="ignition::gazebo::systems::UserCommands" />
    <plugin filename="libignition-gazebo-scene-broadcaster-system.so"
      name="ignition::gazebo::systems::SceneBroadcaster" />
    <plugin filename="libignition-gazebo-sensors-system.so"
      name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="libignition-gazebo-imu-system.so"
      name="ignition::gazebo::systems::Imu" />

    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <!-- Sky-blue fallback clear color: guaranteed to show even if the
           procedural <sky> below fails to render on a given GL backend. -->
      <background>0.53 0.81 0.92 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
      <!-- Procedural atmospheric sky (ogre2, no texture assets needed).
           Verified 2026-07-18 to render correctly under WSL2 software GL
           (LIBGL_ALWAYS_SOFTWARE=1) via scripts/capture_frame.py. Sky pixels
           have no valid depth return (see project_pixels_to_base_link's
           win < 15.0 far-clip filter), so they never reach the line/cone
           detectors regardless of their color -- safe by construction. -->
      <sky></sky>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Collision-only: physics plane. The textured look comes from the
         ground_asphalt include below (visual-only mesh, same 100x100 footprint,
         pose 0 0 0), so the two together give the old ground_plane model's
         combined behavior. -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>150 150</size></plane></geometry>
          <surface><friction><ode><mu>1.0</mu></ode></friction></surface>
        </collision>
      </link>
    </model>

    <!-- Tiled asphalt-grain ground visual (models/ground_asphalt: OBJ quad,
         UVs 0..40 for 40x40 texture tiling, mtl Kd=1 so the PNG's own gray
         value is the final color -- see materials/textures/asphalt.png).
         Replaces the old flat-color <plane> visual (2026-07-18): a plain SDF
         <plane> has no UV-repeat control, so tiled grain needed a custom mesh
         (deferred as a follow-up when the flat gray was first tuned, same
         day).

         IMPORTANT FINDING #1 (from that same original tuning): the file's
         older claim of rendered road "S~5-15" did NOT hold on a later capture
         -- measured saturation was S~76-77, above the detector's sat_max=70
         on its own. The real safety margin has always been the VALUE gate
         (road V~104 vs the val_min=150 floor), not saturation.

         IMPORTANT FINDING #2 (from bringing up this textured mesh): a texture
         whose raw gray NUMERICALLY matches the old flat <diffuse> value
         (~50/255, ~0.196) renders far DARKER than the flat material did --
         measured road BGR ~38-46 vs the flat plane's ~104. Root cause:
         Ignition/ogre2's PBR pipeline sRGB-decodes texture images before
         lighting, but a flat SDF <diffuse> color is applied as linear
         reflectance directly -- the same nominal number goes through an
         extra gamma curve on the texture path that the flat-color path never
         had. (Never a perception-safety problem -- v1 came out too DARK, i.e.
         even further under val_min=150 -- but wrong for visual realism,
         which was the actual point of this change.)

         Fix (scripts baked into the texture generator, not this file): think
         in LINEAR light space (base_linear=0.196, matching the old flat
         diffuse's effective reflectance), add noise there, THEN gamma-encode
         (raw = linear**(1/2.2) * 255) for PNG storage, so decoding it back
         recovers the intended linear value. Current texture: raw gray
         mean~120/255, range 92-143/255 -- estimated rendered V range ~79-123
         (est. via V(linear) ~= 104*(linear/0.196)**(1/2.2), calibrated off
         the flat-plane measurement), comfortably under val_min=150. This
         estimate, like the numbers above, needs reconfirming with a fresh
         capture_frame.py + HSV sweep any time the texture, lighting, or
         renderer changes -- don't trust the math over a live measurement. -->
    <include>
      <name>ground_asphalt</name>
      <uri>model://ground_asphalt</uri>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <!-- Left boundary line (light-gray segments) -->
    <model name="line_L001">
      <static>true</static>
      <pose>0.000 0.500 0.0030 0 0 0.0000</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.360 0.100 0.005</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.95 0.95 0.95 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
            <!-- EMISSIVE: self-illuminate the markings so they render at a high,
                 view- and distance-INDEPENDENT brightness. Without this, ogre2
                 renders the 0.95-albedo lines at only V~106-137 (dimmer up close;
                 see scripts/line_hsv_probe.py), so they never clear val_min=150
                 and the near lane has almost no contrast against the ~100 road.
                 Emissive lifts the lines to V~200+ everywhere, restoring a clean
                 V split between line and road across the whole image. -->
            <emissive>0.7 0.7 0.7 1</emissive>
          </material>
        </visual>
      </link>
    </model>
