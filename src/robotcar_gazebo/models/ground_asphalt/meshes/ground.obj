# 100 x 100 m single quad, normal +Z (up). UV coordinates run 0..40 instead of
# 0..1 so the asphalt texture (materials/textures/asphalt.png) tiles 40x40
# times across the plane (~2.5 m per tile) via the renderer's default texture
# wrap/repeat addressing -- this is how tiled ground grain is done on a mesh,
# unlike SDF's native <plane> geometry which has no UV-repeat control.
mtllib ground.mtl
v -50 -50 0
v  50 -50 0
v  50  50 0
v -50  50 0
vt 0  0
vt 40 0
vt 40 40
vt 0  40
vn 0 0 1
usemtl ground
f 1/1/1 2/2/1 3/3/1 4/4/1
